SECRET_KEY=change-this-to-a-long-random-secret
ADMIN_PASSWORD=change-admin-password

# Optional (contact form notifications)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional (database / visitor storage path)
# Local default: database.db, visitors.json
# Vercel default: /tmp/exam_saarthi/database.db, /tmp/exam_saarthi/visitors.json
DATABASE_PATH=
VISITOR_FILE_PATH=

# Optional cookie override
# true/false (default: true on Vercel, false locally)
SESSION_COOKIE_SECURE=
